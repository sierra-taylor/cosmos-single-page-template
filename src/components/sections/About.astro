---
import type { AboutSection } from "../../types/sections";
import { Image } from "astro:assets";
const { id, heading, description, image, buttonText } =
  Astro.props as AboutSection;
---

<section id="about">
  <div class="flex flex-col md:flex-row items-center md:gap-6">
    <figure>
      <Image src={image} alt="about section image" width={400} height={400} />
    </figure>
    <div>
      <h2 class="text-2xl font-bold">{heading}</h2>
      <p>{description}</p>
      {
        buttonText && (
          <div class="justify-end">
            <button class="btn btn-primary">{buttonText}</button>
          </div>
        )
      }
    </div>
  </div>
</section>
